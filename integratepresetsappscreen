PresetButtons(
    onStashPreset = { flower, extract ->
        flowerGrams = flower
        extractGrams = extract
    },
    onPaycheckPreset = { days ->
        daysUntilPaycheck = days
    },
    onModerationPreset = { flowerUse, extractUse ->
        flowerUsesPerDay = flowerUse
        extractUsesPerDay = extractUse
    }
)
