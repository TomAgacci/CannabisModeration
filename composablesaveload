In App():

var profiles by remember { mutableStateOf(listOf<Profile>()) }
var currentProfileName by remember { mutableStateOf<String?>(null) }

ProfilesPanel(
    currentProfileName = currentProfileName,
    onSaveProfile = { name ->
        val stash = Stash(flowerGrams, extractGrams)
        val pattern = UsePattern(flowerUsesPerDay, extractUsesPerDay)
        val money = Money(moneySpent, costPerGramFlower, costPerGramExtract, budgetUntilPaycheck)
        val profile = Profile(name, stash, pattern, daysUntilPaycheck, money)
        profiles = profiles + profile
        currentProfileName = name
    },
    profiles = profiles,
    onLoadProfile = { p ->
        flowerGrams = p.stash.flowerGrams
        extractGrams = p.stash.extractGrams
        flowerUsesPerDay = p.pattern.flowerUsesPerDay
        extractUsesPerDay = p.pattern.extractUsesPerDay
        daysUntilPaycheck = p.daysUntilPaycheck
        moneySpent = p.money.moneySpent
        costPerGramFlower = p.money.costPerGramFlower
        costPerGramExtract = p.money.costPerGramExtract
        budgetUntilPaycheck = p.money.budgetUntilPaycheck
        currentProfileName = p.name
    }
)



@Composable
fun ProfilesPanel(
    currentProfileName: String?,
    onSaveProfile: (String) -> Unit,
    profiles: List<Profile>,
    onLoadProfile: (Profile) -> Unit
) {
    var name by remember { mutableStateOf(currentProfileName ?: "") }

    Column(verticalArrangement = Arrangement.spacedBy(8.dp)) {
        Text("Profiles", style = MaterialTheme.typography.subtitle1)

        Row {
            TextField(
                value = name,
                onValueChange = { name = it },
                label = { Text("Profile name") },
                modifier = Modifier.weight(1f)
            )
            Button(onClick = { if (name.isNotBlank()) onSaveProfile(name) }) {
                Text("Save")
            }
        }

        Row(horizontalArrangement = Arrangement.spacedBy(8.dp)) {
            profiles.forEach { profile ->
                Button(onClick = { onLoadProfile(profile) }) {
                    Text(profile.name)
                }
            }
        }
    }
}
